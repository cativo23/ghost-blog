<article class="hero-card card">
    <a href="{{url}}" class="hero-card-link">
        <div class="hero-card-image">
            {{#if feature_image}}
            <img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy">
            {{else}}
            <div class="hero-card-gradient"></div>
            {{/if}}
            <div class="hero-card-scanlines"></div>
            <div class="hero-card-badges">
                {{#if featured}}
                <span class="badge badge--featured">FEATURED</span>
                {{/if}}
                {{#foreach tags visibility="internal"}}
                  {{#match slug "~" "series-"}}
                    <span class="badge badge--series">{{name}}</span>
                  {{/match}}
                {{/foreach}}
                <span class="badge badge--time">{{reading_time}}</span>
            </div>
        </div>
        <div class="hero-card-body">
            <div class="tag-pills">
                {{#foreach tags}}
                <span class="tag-pill">#{{slug}}</span>
                {{/foreach}}
            </div>
            <h2 class="hero-card-title">{{title}}</h2>
            <p class="hero-card-excerpt">{{excerpt words="30"}}</p>
            <div class="hero-card-meta">
                <div class="hero-card-author">
                    {{#if primary_author.profile_image}}
                    <img src="{{img_url primary_author.profile_image size="xs"}}" alt="{{primary_author.name}}" class="hero-card-avatar">
                    {{else}}
                    <div class="hero-card-avatar-placeholder"></div>
                    {{/if}}
                    <span class="text-muted">{{primary_author.name}}</span>
                    <span class="text-muted">&middot;</span>
                    <span class="text-muted">{{date format="MMM DD, YYYY"}}</span>
                </div>
                <span class="hero-card-cta mono">cat post.md &rarr;</span>
            </div>
        </div>
    </a>
</article>
