{{!< default}}

{{#post}}
<article class="post-page">
    {{!-- Breadcrumb --}}
    <div class="post-breadcrumb">
        <span class="prompt">
            <span class="prompt-user">cativo</span><span class="prompt-separator">@</span><span class="prompt-path">blog</span><span class="prompt-separator">:~/posts/$</span>
        </span>
        <span class="mono text-muted"> cat {{slug}}.md</span>
    </div>

    {{!-- Post Header --}}
    <header class="post-header">
        <div class="tag-pills">
            {{#foreach tags}}
            <a href="{{url}}" class="tag-pill">#{{slug}}</a>
            {{/foreach}}
        </div>

        {{#foreach tags visibility="internal"}}
          {{#match slug "~" "series-"}}
            <div class="series-badge" data-series-name="{{name}}">
              <span class="series-badge-name"></span>
              <span class="series-badge-separator">•</span>
              <span class="series-badge-position"></span>
            </div>
          {{/match}}
        {{/foreach}}

        <h1 class="post-title">{{title}}</h1>

        <div class="post-meta">
            <div class="post-author">
                {{#if primary_author.profile_image}}
                <img src="{{img_url primary_author.profile_image size="xs"}}" alt="{{primary_author.name}}" class="post-author-avatar">
                {{else}}
                <div class="post-author-avatar-placeholder"></div>
                {{/if}}
                <span class="post-author-name">{{primary_author.name}}</span>
            </div>
            <span class="text-muted">&middot;</span>
            <time class="text-muted" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
            <span class="text-muted">&middot;</span>
            <span class="text-muted">{{reading_time}} min read</span>
        </div>
    </header>

    {{!-- Feature Image --}}
    {{#if feature_image}}
    <div class="post-feature-image">
        <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" loading="lazy">
        <div class="hero-card-scanlines"></div>
    </div>
    {{/if}}

    {{!-- Content + TOC Grid --}}
    <div class="post-grid">
        <div class="post-content" id="post-content">
            {{{content}}}
        </div>
        <aside class="post-sidebar">
            {{> toc}}
        </aside>
    </div>

    {{!-- Series Index --}}
    {{> series-index}}

    {{!-- Share Buttons --}}
    <section class="post-share">
        <div class="post-share-buttons">
            <button class="btn post-share-btn" id="share-copy" data-url="{{url absolute="true"}}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span>Copy link</span>
            </button>
            <a class="btn post-share-btn" href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&text={{encode title}}" target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <span>Share on X</span>
            </a>
            <a class="btn post-share-btn" href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true"}}" target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span>LinkedIn</span>
            </a>
        </div>
    </section>

    {{!-- Giscus Comments --}}
    {{> giscus}}

    {{!-- Related Posts --}}
    {{#get "posts" filter="tags:[{{primary_tag.slug}}]+id:-{{id}}" limit="2" include="tags,authors"}}
    {{#if posts.length}}
    <section class="related-posts">
        <div class="related-header">
            <span class="prompt">
                <span class="prompt-user">cativo</span><span class="prompt-separator">@</span><span class="prompt-path">blog</span><span class="prompt-separator">:~$</span>
            </span>
            <span class="mono text-muted"> ls related/</span>
        </div>
        <div class="related-grid">
            {{#foreach posts}}
            <a href="{{url}}" class="related-card card">
                {{#if feature_image}}
                <div class="related-card-image">
                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy">
                </div>
                {{/if}}
                <div class="related-card-body">
                    <div class="tag-pills">
                        {{#foreach tags limit="2"}}
                        <span class="tag-pill">{{name}}</span>
                        {{/foreach}}
                    </div>
                    <h3 class="related-card-title">{{title}}</h3>
                    <p class="related-card-excerpt text-muted">{{excerpt words="15"}}</p>
                    <span class="mono text-muted" style="font-size: 12px;">{{date format="MMM DD"}} &middot; {{reading_time}} min</span>
                </div>
            </a>
            {{/foreach}}
        </div>
    </section>
    {{/if}}
    {{/get}}
</article>
{{/post}}
