{{!< default}}

{{#post}}
<main class="container">
    <article class="page-content">
        {{!-- Page Breadcrumb --}}
        <div class="page-breadcrumb">
            <span class="prompt">
                <span class="prompt-user">cativo</span><span class="prompt-separator">@</span><span class="prompt-path">blog</span><span class="prompt-separator">:~/pages/$</span>
            </span>
            <span class="mono text-muted"> cat {{slug}}.md</span>
        </div>

        {{!-- Page Header --}}
        <header class="page-header">
            <h1 class="page-title">{{title}}</h1>
        </header>

        {{!-- Page Body --}}
        <div class="page-body post-content">
            {{{content}}}
        </div>
    </article>
</main>

<style>
.page-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 0;
}

.page-breadcrumb {
    margin-bottom: 24px;
    font-size: 13px;
}

.page-header {
    margin-bottom: 32px;
}

.page-title {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.5px;
    line-height: 1.2;
}

.page-body {
    max-width: 720px;
}
</style>
{{/post}}
